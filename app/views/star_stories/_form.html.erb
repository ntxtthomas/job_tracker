<%= form_with(model: star_story) do |form| %>
  <% if star_story.errors.any? %>
    <div class="alert">
      <h2><%= pluralize(star_story.errors.count, "error") %> prohibited this STAR story from being saved:</h2>

      <ul>
        <% star_story.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= form.label :title, class: "form-label" %>
    <%= form.text_field :title, class: "form-input" %>
  </div>

  <div class="form-group">
    <%= form.label :situation, class: "form-label" %>
    <%= form.text_area :situation, rows: 4, class: "form-textarea" %>
  </div>

  <div class="form-group">
    <%= form.label :task, class: "form-label" %>
    <%= form.text_area :task, rows: 4, class: "form-textarea" %>
  </div>

  <div class="form-group">
    <%= form.label :action, class: "form-label" %>
    <%= form.text_area :action, rows: 4, class: "form-textarea" %>
  </div>

  <div class="form-group">
    <%= form.label :result, class: "form-label" %>
    <%= form.text_area :result, rows: 4, class: "form-textarea" %>
  </div>

  <div class="form-group">
    <%= form.label :skills, "Skills (one per line)", class: "form-label" %>
    <%= form.text_area :skills, value: star_story.skills&.join("\n"), rows: 3, class: "form-textarea" %>
    <small class="form-hint">Enter each skill on a new line</small>
  </div>

  <div class="form-group">
    <%= form.label :category, class: "form-label" %>
    <%= form.select :category, StarStory.categories.keys.map { |k| [k.titleize, k] }, { prompt: "Select a category" }, { class: "form-select" } %>
  </div>

  <div class="form-group">
    <%= form.label :outcome, class: "form-label" %>
    <%= form.select :outcome, StarStory.outcomes.keys.map { |k| [k.titleize, k] }, { prompt: "Select an outcome" }, { class: "form-select" } %>
  </div>

  <div class="form-group">
    <%= form.label :strength_score, "Strength Score (1-10)", class: "form-label" %>
    <%= form.number_field :strength_score, min: 1, max: 10, class: "form-input" %>
    <small class="form-hint">How compelling/impactful is this story? (1=weak, 10=very strong)</small>
  </div>

  <div class="form-group">
    <%= form.label :notes, "Notes/Reflection", class: "form-label" %>
    <%= form.text_area :notes, rows: 4, class: "form-textarea" %>
  </div>

  <div class="form-group">
    <%= form.label :opportunity_ids, "Related Opportunities", class: "form-label" %>
    <%= form.collection_select :opportunity_ids, Opportunity.all.order(:position_title), :id, :position_title, {}, { multiple: true, class: "form-select" } %>
  </div>

  <div class="form-actions">
    <%= form.submit class: "btn btn-primary" %>
  </div>
<% end %>