<% if notice.present? %>
  <p class="notice"><%= notice %></p>
<% end %>

<% content_for :title, "STAR Stories" %>

<div class="page-header">
  <div class="page-header-content">
    <h1 class="page-title">STAR Stories</h1>
    <div class="page-actions">
      <%= link_to "+", new_star_story_path, class: "btn btn-primary btn-lg" %>
      <%= link_to "Download", star_stories_path(format: :csv), class: "btn btn-secondary" %>
    </div>
  </div>
</div>

<div id="star_stories" class="table-container">
  <table>
    <thead>
      <tr>
        <th class="star-story-order-column">
          <button type="button" id="star-story-order-sort" class="star-story-order-sort-btn">Order ▲</button>
        </th>
        <th>Title</th>
        <th>Situation</th>
        <th>Task</th>
        <th>Action</th>
        <th>Result</th>
        <th>Skills</th>
        <th>Category</th>
        <th>Outcome</th>
        <th>Notes</th>
      </tr>
    </thead>
    <tbody>
      <% @star_stories.each do |star_story| %>
        <tr id="<%= dom_id star_story %>" class="clickable-row" data-href="<%= star_story_path(star_story) %>">
          <td class="star-story-order-column">
            <input type="number" min="1" class="form-input star-story-order-input" aria-label="Temporary order for <%= star_story.title %>">
          </td>
          <td><%= star_story.title %></td>
          <td class="table-cell-wrap"><%= truncate(star_story.situation, length: 200) %></td>
          <td class="table-cell-wrap"><%= truncate(star_story.task, length: 200) %></td>
          <td class="table-cell-wrap"><%= truncate(star_story.action, length: 200) %></td>
          <td class="table-cell-wrap"><%= truncate(star_story.result, length: 200) %></td>
          <td><%= star_story.skills&.join(", ") %></td>
          <td><%= star_story.category&.titleize %></td>
          <td><%= star_story.outcome&.titleize %></td>
          <td class="table-cell-wrap"><%= truncate(star_story.notes, length: 200) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>


