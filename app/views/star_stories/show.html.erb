<% if notice.present? %>
  <p class="notice"><%= notice %></p>
<% end %>

<% content_for :title, @star_story.title %>

<h1><%= @star_story.title %></h1>

<div class="detail-section">
  <div class="detail-value">
    <strong>Category:</strong> <%= @star_story.category&.titleize %> |
    <strong>Outcome:</strong> <%= @star_story.outcome&.titleize %> |
    <strong>Strength:</strong> <%= @star_story.strength_score %>/10
  </div>

  <div class="detail-section">
    <h3 class="detail-label">Situation</h3>
    <p class="detail-value-wrap"><%= @star_story.situation %></p>
  </div>

  <div class="detail-section">
    <h3 class="detail-label">Task</h3>
    <p class="detail-value-wrap"><%= @star_story.task %></p>
  </div>

  <div class="detail-section">
    <h3 class="detail-label">Action</h3>
    <p class="detail-value-wrap"><%= @star_story.action %></p>
  </div>

  <div class="detail-section">
    <h3 class="detail-label">Result</h3>
    <p class="detail-value-wrap"><%= @star_story.result %></p>
  </div>

  <% if @star_story.skills&.any? %>
    <div class="detail-section">
      <strong class="detail-label">Skills:</strong>
      <div class="skill-list">
        <% @star_story.skills.each do |skill| %>
          <span class="skill-badge"><%= skill %></span>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if @star_story.notes.present? %>
    <div class="detail-section">
      <h3 class="detail-label">Notes</h3>
      <p class="detail-value-wrap"><%= @star_story.notes %></p>
    </div>
  <% end %>

  <% if @star_story.opportunities.any? %>
    <div class="detail-section">
      <h3 class="detail-label">Related Opportunities</h3>
      <ul>
        <% @star_story.opportunities.each do |opportunity| %>
          <li><%= link_to opportunity.position_title, opportunity %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
</div>

<div class="form-actions">
  <%= link_to "Edit this STAR story", edit_star_story_path(@star_story), class: "btn btn-primary" %>
  <%= link_to "Back to STAR stories", star_stories_path, class: "btn btn-secondary" %>
  <%= button_to "Destroy this STAR story", @star_story, method: :delete, class: "btn btn-danger", data: { confirm: "Are you sure?" } %>
</div>
