<% if notice.present? %>
  <p class="notice"><%= notice %></p>
<% end %>

<% content_for :title, "Opportunities" %>

<div class="page-header">
  <div class="page-header-content">
    <div>
      <h1 class="page-title">Opportunities</h1>
      <% if @date_filter %>
        <p class="opportunities-date-filter-note">
          Showing applications from <%= @date_filter %>
          <%= link_to "Clear filter", opportunities_path, class: "opportunities-date-filter-clear" %>
        </p>
      <% end %>
    </div>
  </div>
</div>

  <!-- Status Filter -->
  <div class="card opportunities-filters-card">
    <div class="opportunities-toolbar">
      <div class="opportunities-filter-group">
        <%= form_with url: opportunities_path, method: :get, local: true, class: "opportunities-filter-form" do |f| %>
          <%= hidden_field_tag :company_query, params[:company_query] %>
          <%= hidden_field_tag :start_date, params[:start_date] %>
          <%= hidden_field_tag :end_date, params[:end_date] %>
          <label for="status_filter" class="form-label opportunities-status-label"></label>
          <%= f.select :status,
              options_for_select([
                ["Applied", "applied"],
                ["Interviewing", "interviewing"],
                ["Closed", "closed"]
              ], params[:status]),
              { include_blank: "All Statuses" },
              id: "status_filter",
              class: "form-select opportunities-status-select" %>
          <%= f.submit "Filter", class: "btn btn-primary" %>
          <% if params[:status].present? %>
            <%= link_to "Clear", opportunities_path(company_query: params[:company_query], start_date: params[:start_date], end_date: params[:end_date]), class: "btn btn-secondary" %>
          <% end %>
        <% end %>
        |
        <%= form_with url: opportunities_path, method: :get, local: true, class: "opportunities-filter-form" do |f| %>
          <%= hidden_field_tag :status, params[:status] %>
          <%= hidden_field_tag :start_date, params[:start_date] %>
          <%= hidden_field_tag :end_date, params[:end_date] %>
          <%= f.text_field :company_query, value: params[:company_query], placeholder: "Search company", class: "form-input opportunities-company-input" %>
          <%= f.submit "Search", class: "btn btn-primary" %>
          <% if params[:company_query].present? %>
            <%= link_to "Clear", opportunities_path(status: params[:status], start_date: params[:start_date], end_date: params[:end_date]), class: "btn btn-secondary" %>
          <% end %>
        <% end %>
      </div>

      <div class="opportunities-actions">
        <%= link_to "+", new_opportunity_path, class: "btn btn-primary btn-lg" %>
        <%= link_to "Download CSV", opportunities_path(format: :csv, status: params[:status], company_query: params[:company_query], start_date: params[:start_date], end_date: params[:end_date]), class: "btn btn-secondary" %>
      </div>
    </div>
  </div>

<div id="opportunities" class="table-container">
  <table>
    <thead>
      <tr>
        <th><%= sortable_link :role_type, "Role Type" %></th>
        <th><%= sortable_link :company %></th>
        <th><%= sortable_link :position_title, "Position" %></th>
        <th><%= sortable_link :application_date, "Application Date" %></th>
        <th><%= sortable_link :status %></th>
        <th><%= sortable_link :source %></th>
        <th><%= sortable_link :tech_stack, "Tech Stack" %></th>
        <th><%= sortable_link :salary_range, "Salary Range" %></th>
        <th><%= sortable_link :bus_factor, "Bus Factor" %></th>
        <th><%= sortable_link :chatgpt_match, "ChatGPT" %></th>
        <th><%= sortable_link :jobright_match, "Jobright" %></th>
        <th><%= sortable_link :linkedin_match, "LinkedIn" %></th>
      </tr>
    </thead>
    <tbody>
      <% @opportunities.each do |opportunity| %>
      <%= render opportunity %>
      <% end %>
    </tbody>
  </table>
</div>
