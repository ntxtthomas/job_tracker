<% if notice.present? %>
  <p class="notice"><%= notice %></p>
<% end %>

<% content_for :title, "Opportunities" %>

<div class="page-header">
  <div class="page-header-content">
    <div>
      <h1 class="page-title">Opportunities</h1>
      <% if @date_filter %>
        <p style="margin: 0.5rem 0 0 0; color: var(--text-muted); font-size: 0.95rem;">
          Showing applications from <%= @date_filter %>
          <%= link_to "Clear filter", opportunities_path, style: "margin-left: 1rem;" %>
        </p>
      <% end %>
    </div>
  </div>
</div>

  <!-- Role Type Filter -->
  <div class="card" style="margin-bottom: 1rem;">
    <div style="display: flex; gap: 10px; align-items: center; flex-wrap: wrap; width: 100%;">
      <%= form_with url: opportunities_path, method: :get, local: true, style: "display: flex; gap: 10px; align-items: center; flex-wrap: wrap;" do |f| %>
        <label for="role_type_filter" class="form-label" style="margin: 0;">Filter by Role Type:</label>
        <%= f.select :role_type,
            options_for_select(Opportunity::ROLE_TYPES.map { |k, v| [v, k] }, params[:role_type]),
            { include_blank: "All Roles" },
            id: "role_type_filter",
            class: "form-select",
            style: "width: auto; min-width: 200px;" %>
        <%= f.submit "Filter", class: "btn btn-primary" %>
        <% if params[:role_type].present? %>
          <%= link_to "Clear", opportunities_path, class: "btn btn-secondary" %>
        <% end %>
      <% end %>
      <div style="margin-left: auto; display: flex; gap: 10px;">
        <%= link_to "+", new_opportunity_path, class: "btn btn-primary btn-lg" %>
        <%= link_to "Download CSV", opportunities_path(format: :csv, start_date: params[:start_date], end_date: params[:end_date]), class: "btn btn-secondary" %>
      </div>
    </div>
  </div>

<div id="opportunities" class="table-container">
  <table>
    <thead>
      <tr>
        <th><%= sortable_link :role_type, "Role Type" %></th>
        <th><%= sortable_link :company %></th>
        <th><%= sortable_link :position_title, "Position" %></th>
        <th><%= sortable_link :application_date, "Application Date" %></th>
        <th><%= sortable_link :status %></th>
        <th><%= sortable_link :source %></th>
        <th><%= sortable_link :tech_stack, "Tech Stack" %></th>
        <th><%= sortable_link :salary_range, "Salary Range" %></th>
        <th><%= sortable_link :bus_factor, "Bus Factor" %></th>
        <th><%= sortable_link :chatgpt_match, "ChatGPT" %></th>
        <th><%= sortable_link :jobright_match, "Jobright" %></th>
        <th><%= sortable_link :linkedin_match, "LinkedIn" %></th>
      </tr>
    </thead>
    <tbody>
      <% @opportunities.each do |opportunity| %>
      <%= render opportunity %>
      <% end %>
    </tbody>
  </table>
</div>
