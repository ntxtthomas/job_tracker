<% content_for :title, "Dashboard" %>

<h1>Job Tracker Dashboard</h1>

<!-- Upper Section: Main Stats, Focus Insights, Source, Weekly Apps -->
<div style="display: flex; gap: 2rem; flex-wrap: wrap; margin-bottom: 2rem;">
  <!-- Left Column: Total Applications & Assessed Opportunities -->
  <div style="display: flex; flex-direction: column; gap: 1rem; flex: 0 0 280px; min-width: 280px;">
    <div class="dashboard-cards" style="flex: 1;">
      <div class="card card-submitted">
        <div class="card-header">
          <h3>Total Applications Submitted</h3>
          <div class="card-icon">📋</div>
        </div>
        <div class="card-body">
          <div class="card-number"><%= @total_resumes %></div>
          <p class="card-subtitle">Total applications sent</p>
        </div>
      </div>
    </div>

    <div class="dashboard-cards" style="flex: 1;">
      <div class="card card-assessed">
        <div class="card-header">
          <h3>Assessed Opportunities</h3>
          <div class="card-icon">🎯</div>
        </div>
        <div class="card-body">
          <div class="card-number"><%= @total_assessed %></div>
          <p class="card-subtitle">Total opportunities tracked</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Middle Column: Top 4 Tech Skills & Source Distribution -->
  <div style="display: flex; flex-direction: column; gap: 1rem; flex: 1; min-width: 400px;">
    <% if @focus_insights.any? %>
      <div class="dashboard-cards" style="flex: 1;">
        <div class="card">
          <div class="card-header">
            <h3>🎯 Top 4 Tech Skills to Focus On</h3>
            <div class="card-icon">📚</div>
          </div>
          <div class="card-body">
            <div style="padding: 10px 0;">
              <% @focus_insights.each_with_index do |insight, index| %>
                <div style="margin-bottom: 20px; padding: 15px; background-color: <%= index == 0 ? 'rgba(111, 66, 193, 0.05)' : 'var(--bg-primary, #fff)' %>; border-left: 4px solid <%= index == 0 ? '#6f42c1' : '#dee2e6' %>; border-radius: 4px;">
                  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
                    <div>
                      <span style="font-weight: bold; font-size: 16px; color: var(--text-primary, #333);"><%= index + 1 %>. <%= insight[:name] %></span>
                      <% if index == 0 %>
                        <span style="background-color: #6f42c1; color: white; padding: 2px 8px; border-radius: 3px; font-size: 11px; margin-left: 8px; font-weight: bold;">TOP PRIORITY</span>
                      <% end %>
                    </div>
                    <% if insight[:percentage].present? %>
                      <span style="font-size: 20px; font-weight: bold; color: #6f42c1;"><%= insight[:percentage] %>%</span>
                    <% end %>
                  </div>
                  <div style="font-size: 14px; color: var(--text-secondary, #666); margin-bottom: 5px;">
                    <%= insight[:insight] %>
                  </div>
                  <% if insight[:count].present? %>
                    <div style="font-size: 12px; color: var(--text-tertiary, #999);">
                      Appears in <strong><%= insight[:count] %></strong> of your tracked opportunities
                    </div>
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <% if @source_data.any? %>
      <div class="dashboard-cards" style="flex: 0;">
        <div class="card">
          <div class="card-header">
            <h3>Source Distribution</h3>
            <div class="card-icon">🔍</div>
          </div>
          <div class="card-body">
            <div class="tech-stack-chart">
              <% max_count_source = @source_data.values.max %>
              <% @source_data.first(6).each do |source, count| %>
                <div class="chart-bar-container" style="margin-bottom: 8px;">
                  <div class="chart-label" style="min-width: 100px; font-size: 13px;"><%= source&.humanize %></div>
                  <div class="chart-bar-wrapper">
                    <div class="chart-bar" style="width: <%= (count.to_f / max_count_source * 100).round(1) %>%;">
                      <span class="chart-count"><%= count %></span>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Right Column: Applications by Week -->
  <div style="display: flex; flex-direction: column; gap: 1rem; flex: 0 0 320px; min-width: 320px;">
    <div class="dashboard-cards" style="flex: 1;">
      <div class="card">
        <div class="card-header">
          <h3>Applications by Week</h3>
          <div class="card-icon">📅</div>
        </div>
        <div class="card-body">
          <div class="dashboard-cards weekly-cards" style="margin: 0;">
            <% @weekly_data.each_with_index do |week, index| %>
              <% card_class = week[:meets_requirement] ? "card card-week card-week-success clickable-week-card" : "card card-week card-week-warning clickable-week-card" %>
              <%= link_to opportunities_path(start_date: week[:start_date], end_date: week[:end_date]), class: card_class, style: "text-decoration: none; color: inherit;" do %>
                <div class="card-header">
                  <h3><%= week[:label] %></h3>
                  <div class="card-icon">📅</div>
                </div>
                <div class="card-body">
                  <div class="card-number"><%= week[:count] %></div>
                  <p class="card-subtitle">applications</p>
                </div>
              <% end %>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Lower Section: Individual Role Focus Widgets -->
<% if @all_role_insights.any? %>
  <%
    # Define role badge colors
    role_colors = {
      "software_engineer" => "#6c757d",
      "sales_engineer" => "#28a745",
      "solutions_engineer" => "#17a2b8",
      "product_manager" => "#6f42c1",
      "support_engineer" => "#fd7e14",
      "success_engineer" => "#20c997",
      "other" => "#343a40"
    }
  %>
  
  <div style="margin-top: 3rem;">
    <h2 style="margin-bottom: 1.5rem; color: var(--text-primary);">Focus Areas by Role Type</h2>
    <div class="dashboard-cards" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem;">
      <% @all_role_insights.each do |role_type, data| %>
        <% next if role_type == @primary_role %> <!-- Skip primary role as it's shown above -->
        <% badge_color = role_colors[role_type] || "#6c757d" %>
        
        <div class="card" style="border-left-color: <%= badge_color %>;">
          <div class="card-header">
            <div>
              <h3 style="margin-bottom: 0.5rem;"><%= data[:label] %></h3>
              <p style="margin: 0; font-size: 12px; color: var(--text-muted);"><%= data[:count] %> <%= data[:count] == 1 ? 'opportunity' : 'opportunities' %></p>
            </div>
            <div class="card-icon">💼</div>
          </div>
          <div class="card-body" style="text-align: left;">
            <div style="padding: 5px 0;">
              <% data[:insights].each_with_index do |insight, index| %>
                <div style="margin-bottom: 15px; padding-bottom: 15px; <%= index < data[:insights].length - 1 ? 'border-bottom: 1px solid var(--border-color);' : '' %>">
                  <div style="font-weight: 600; font-size: 14px; color: var(--text-primary); margin-bottom: 4px;">
                    <%= index + 1 %>. <%= insight[:name] %>
                  </div>
                  <div style="font-size: 12px; color: var(--text-secondary); line-height: 1.4;">
                    <%= insight[:insight] %>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
