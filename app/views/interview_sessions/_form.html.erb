<% selected_company_id = params[:company_id].presence || interview_session.opportunity&.company_id %>

<%= form_with(
  model: interview_session,
  data: {
    controller: "interview-session-form",
    interview_session_form_opportunities_value: @opportunity_scope_data.to_json,
    interview_session_form_contacts_value: @contact_scope_data.to_json
  }
) do |form| %>
  <% if interview_session.errors.any? %>
    <div class="alert">
      <h2><%= pluralize(interview_session.errors.count, "error") %> prohibited this interview session from being saved:</h2>
      <ul>
        <% interview_session.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= label_tag :company_id, "Company", class: "form-label" %>
    <%= select_tag :company_id,
      options_from_collection_for_select(@companies, :id, :name, selected_company_id),
      prompt: "Select a company",
      class: "form-select",
      data: {
        interview_session_form_target: "company",
        action: "change->interview-session-form#companyChanged"
      } %>
  </div>

  <div class="form-group">
    <%= form.label :opportunity_id, "Opportunity", class: "form-label" %>
    <%= form.select :opportunity_id,
      options_for_select(@opportunity_select_options, interview_session.opportunity_id),
      { prompt: "Select an opportunity" },
      {
        class: "form-select",
        data: {
          interview_session_form_target: "opportunity",
          action: "change->interview-session-form#opportunityChanged"
        }
      } %>
  </div>

  <div class="form-group">
    <%= form.label :contact_id, "Contact (Interviewer/Recruiter)", class: "form-label" %>
    <%= form.select :contact_id,
      options_for_select(@contact_select_options, interview_session.contact_id),
      { prompt: "Optional contact" },
      {
        class: "form-select",
        data: {
          interview_session_form_target: "contact"
        }
      } %>
  </div>

  <div class="form-group">
    <%= form.label :stage, class: "form-label" %>
    <%= form.select :stage, InterviewSession.stages.keys.map { |key| [key.humanize, key] }, { prompt: "Select stage" }, class: "form-select" %>
  </div>

  <div class="form-group">
    <%= form.label :format, class: "form-label" %>
    <%= form.select :format, InterviewSession.formats.keys.map { |key| [key.humanize, key] }, { prompt: "Select format" }, class: "form-select" %>
  </div>

  <div class="form-group">
    <%= form.label :status, class: "form-label" %>
    <%= form.select :status, InterviewSession.statuses.keys.map { |key| [key.humanize, key] }, { prompt: "Select status" }, class: "form-select" %>
  </div>

  <div class="form-group">
    <%= form.label :scheduled_at, class: "form-label" %>
    <%= form.datetime_local_field :scheduled_at, class: "form-input" %>
  </div>

  <div class="form-group">
    <%= form.label :duration_minutes, class: "form-label" %>
    <%= form.number_field :duration_minutes, class: "form-input", min: 1 %>
  </div>

  <div class="form-group">
    <%= form.label :overall_signal, class: "form-label" %>
    <%= form.select :overall_signal, InterviewSession.overall_signals.keys.map { |key| [key.humanize, key] }, { prompt: "Optional signal" }, class: "form-select" %>
  </div>

  <div class="form-group">
    <%= form.label :confidence_score, "Confidence Score (0-10)", class: "form-label" %>
    <%= form.number_field :confidence_score, class: "form-input", min: 0, max: 10 %>
  </div>

  <div class="form-group full-width-field">
    <%= form.label :notes, class: "form-label" %>
    <%= form.rich_text_area :notes %>
  </div>

  <div class="form-group full-width-field">
    <%= form.label :questions_they_asked, class: "form-label" %>
    <%= form.text_area :questions_they_asked, class: "form-textarea", rows: 4 %>
  </div>

  <div class="form-group full-width-field">
    <%= form.label :questions_i_asked, class: "form-label" %>
    <%= form.text_area :questions_i_asked, class: "form-textarea", rows: 4 %>
  </div>

  <div class="form-group full-width-field">
    <%= form.label :follow_ups, class: "form-label" %>
    <%= form.text_area :follow_ups, class: "form-textarea", rows: 3 %>
  </div>

  <div class="form-group full-width-field">
    <%= form.label :next_steps, class: "form-label" %>
    <%= form.text_area :next_steps, class: "form-textarea", rows: 3 %>
  </div>

  <div class="form-actions">
    <%= form.submit class: "btn btn-primary" %>
  </div>
<% end %>