<%= form_with(model: company) do |form| %>
<% if company.errors.any? %>
<div class="alert">
  <h2><%= pluralize(company.errors.count, "error") %> prohibited this company from being saved:</h2>

  <ul>
    <% company.errors.each do |error| %>
    <li><%= error.full_message %></li>
    <% end %>
  </ul>
</div>
<% end %>

<div class="form-group">
  <%= form.label :name, class: "form-label" %>
  <%= form.text_field :name, class: "form-input" %>
</div>

<div class="form-group">
  <%= form.label :industry, class: "form-label" %>
  <%= form.text_field :industry, class: "form-input" %>
</div>

<div class="form-group">
  <%= form.label :company_type, "Company Type", class: "form-label" %>
  <%= form.select :company_type, 
      [["Select a type...", ""], 
       ["Product / Platform", "Product"], 
       ["Consultancy / Agency", "Consultancy"], 
       ["Staffing / Contract", "Staffing"]], 
      {}, 
      class: "form-select" %>
</div>

<div class="form-group">
  <%= form.label :location, class: "form-label" %>
  <%= form.text_field :location, class: "form-input" %>
</div>

<div class="form-group">
  <%= form.label :size, "Company Size (Employee Range)", class: "form-label" %>
  <%= form.text_field :size, placeholder: "e.g., 501-1,000", class: "form-input" %>
</div>

<div class="form-group">
  <%= form.label :website, class: "form-label" %>
  <%= form.url_field :website, placeholder: "https://...", class: "form-input" %>
</div>

<div class="form-group">
  <%= form.label :linkedin, class: "form-label" %>
  <%= form.url_field :linkedin, placeholder: "https://linkedin.com/...", class: "form-input" %>
</div>

<div class="form-group">
  <%= form.label :known_tech_stack, "Known Technologies", class: "form-label" %>
  <p class="form-hint">
    Technologies this company uses (from research, website, job postings, etc.)
  </p>
  <div style="max-height: 300px; overflow-y: auto; border: 1px solid #ddd; padding: 10px; border-radius: 4px; background-color: var(--bg-primary, #fff);">
    <% Technology::CATEGORIES.each do |category| %>
      <% techs = Technology.where(category: category).order(:name) %>
      <% next if techs.empty? %>
      
      <fieldset style="margin-bottom: 15px; border: none; padding: 0;">
        <legend style="font-weight: bold; color: var(--text-primary, #333); margin-bottom: 5px;"><%= category %></legend>
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 5px;">
          <% techs.each do |tech| %>
            <label style="display: flex; align-items: center; cursor: pointer;">
              <% known_techs = company.known_tech_stack.present? ? company.known_tech_stack.split(',').map(&:strip) : [] %>
              <input type="checkbox" name="company[known_tech_stack_list][]" value="<%= tech.name %>" 
                <%= 'checked' if known_techs.include?(tech.name) %> />
              <span style="margin-left: 5px; font-size: 14px;"><%= tech.name %></span>
            </label>
          <% end %>
        </div>
      </fieldset>
    <% end %>
  </div>
  <%= hidden_field_tag "company[known_tech_stack_list][]", "" %>
</div>

<div class="detail-section" style="margin-top: 30px; padding-top: 20px; border-top: 2px solid var(--border-color);">
  <h3 class="detail-label">Company Intelligence</h3>
  
  <div class="form-group">
    <%= form.label :primary_product, class: "form-label" %>
    <%= form.text_area :primary_product, rows: 3, class: "form-textarea" %>
  </div>

  <div class="form-group">
    <%= form.label :revenue_model, class: "form-label" %>
    <%= form.select :revenue_model, [["Select...", ""], ["SaaS", "SaaS"], ["Enterprise License", "Enterprise License"], ["Freemium", "Freemium"], ["Marketplace", "Marketplace"], ["Advertising", "Advertising"], ["Consulting", "Consulting"]], {}, { class: "form-select" } %>
  </div>

  <div class="form-group">
    <%= form.label :funding_stage, class: "form-label" %>
    <%= form.select :funding_stage, [["Select...", ""], ["Bootstrapped", "Bootstrapped"], ["Seed", "Seed"], ["Series A", "Series A"], ["Series B", "Series B"], ["Series C+", "Series C+"], ["Public", "Public"], ["Acquired", "Acquired"]], {}, { class: "form-select" } %>
  </div>

  <div class="form-group">
    <%= form.label :estimated_revenue, class: "form-label" %>
    <%= form.text_field :estimated_revenue, placeholder: "e.g., $10M-$50M ARR", class: "form-input" %>
  </div>

  <div class="form-group">
    <%= form.label :estimated_employees, class: "form-label" %>
    <%= form.number_field :estimated_employees, class: "form-input" %>
  </div>

  <div class="form-group">
    <%= form.label :growth_signal, class: "form-label" %>
    <%= form.select :growth_signal, [["Select...", ""], ["Rapid Growth", "Rapid Growth"], ["Steady Growth", "Steady Growth"], ["Stable", "Stable"], ["Declining", "Declining"], ["Unknown", "Unknown"]], {}, { class: "form-select" } %>
  </div>

  <div class="form-group">
    <%= form.label :product_maturity, "Product Maturity (1-10)", class: "form-label" %>
    <%= form.number_field :product_maturity, min: 1, max: 10, class: "form-input" %>
    <small class="form-hint">1=early prototype, 10=mature/established</small>
  </div>

  <div class="form-group">
    <%= form.label :engineering_maturity, "Engineering Maturity (1-10)", class: "form-label" %>
    <%= form.number_field :engineering_maturity, min: 1, max: 10, class: "form-input" %>
    <small class="form-hint">1=chaos, 10=world-class practices</small>
  </div>

  <div class="form-group">
    <%= form.label :process_maturity, "Process Maturity (1-10)", class: "form-label" %>
    <%= form.number_field :process_maturity, min: 1, max: 10, class: "form-input" %>
    <small class="form-hint">1=ad-hoc, 10=optimized</small>
  </div>

  <div class="form-group">
    <%= form.label :market_position, class: "form-label" %>
    <%= form.select :market_position, [["Select...", ""], ["Market Leader", "Market Leader"], ["Strong Challenger", "Strong Challenger"], ["Niche Player", "Niche Player"], ["Emerging", "Emerging"], ["Unknown", "Unknown"]], {}, { class: "form-select" } %>
  </div>

  <div class="form-group">
    <%= form.label :competitor_tier, class: "form-label" %>
    <%= form.select :competitor_tier, [["Select...", ""], ["Tier 1 (FAANG-level)", "Tier 1"], ["Tier 2 (Unicorn/Strong)", "Tier 2"], ["Tier 3 (Mid-market)", "Tier 3"], ["Tier 4 (Small/Startup)", "Tier 4"]], {}, { class: "form-select" } %>
  </div>

  <div class="form-group">
    <%= form.label :brand_signal_strength, "Brand Signal Strength (1-10)", class: "form-label" %>
    <%= form.number_field :brand_signal_strength, min: 1, max: 10, class: "form-input" %>
    <small class="form-hint">1=unknown, 10=household name</small>
  </div>

  <div class="form-group">
    <%= form.label :market_size_estimate, class: "form-label" %>
    <%= form.text_area :market_size_estimate, rows: 2, placeholder: "e.g., TAM $50B, growing 20% YoY", class: "form-textarea" %>
  </div>
</div>

<div class="form-actions">
  <%= form.submit class: "btn btn-primary" %>
</div>
<% end %>
