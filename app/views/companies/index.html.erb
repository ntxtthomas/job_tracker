<% if notice.present? %>
  <p class="notice"><%= notice %></p>
<% end %>

<% content_for :title, "Companies" %>

<div class="page-header">
  <div class="page-header-content">
    <h1 class="page-title">Companies</h1>
  </div>
</div>

<div class="card" style="margin-bottom: 20px;">
  <div style="display: flex; gap: 10px; align-items: center; flex-wrap: wrap; width: 100%;">
    <%= form_with url: companies_path, method: :get, local: true, style: "display: flex; gap: 10px; align-items: center; flex-wrap: wrap;" do |f| %>
      <label for="technology_filter" class="form-label" style="margin: 0;">Filter by technology:</label>
      <%= f.select :technology, 
          options_from_collection_for_select(@technologies, :name, :name, @selected_technology),
          { include_blank: "All Technologies" },
          id: "technology_filter",
          class: "form-select",
          style: "width: auto; min-width: 200px;" %>
      <%= f.submit "Filter", class: "btn btn-primary" %>
      <% if @selected_technology.present? %>
        <%= link_to "Clear", companies_path, class: "btn btn-secondary" %>
      <% end %>
    <% end %>
    <div style="margin-left: auto; display: flex; gap: 10px;">
      <%= link_to "+", new_company_path, class: "btn btn-primary btn-lg" %>
    </div>
  </div>
</div>

<div id="companies" class="table-container">
  <table>
    <thead>
      <tr>
        <th><%= sortable_link :name %></th>
        <th><%= sortable_link :industry %></th>
        <th><%= sortable_link :company_type, "Type" %></th>
        <th><%= sortable_link :location %></th>
        <th><%= sortable_link :size, "Size" %></th>
        <th><%= sortable_link :website %></th>
        <th><%= sortable_link :linkedin %></th>
        <th>Tech Stack</th>
      </tr>
    </thead>
    <tbody>
      <% @companies.each do |company| %>
      <%= render company %>
      <% end %>
    </tbody>
  </table>
</div>
